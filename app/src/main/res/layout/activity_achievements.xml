<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="18dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="全部勋章"
            android:textAppearance="@style/TextAppearance.DayMark.Headline.Medium" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:text="返回"
            android:textSize="14sp"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <!-- 统计信息 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="18dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:contentPadding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/unlockedCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="已获得: 0"
                android:textAppearance="@style/TextAppearance.DayMark.Body.Large"
                android:textColor="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:text="/"
                android:textAppearance="@style/TextAppearance.DayMark.Body.Large"
                android:textColor="@color/onSurfaceVariant" />

            <TextView
                android:id="@+id/totalCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="总计: 0"
                android:textAppearance="@style/TextAppearance.DayMark.Body.Large"
                android:textColor="@color/onSurfaceVariant" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 勋章列表 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/achievementsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingBottom="18dp" />
    </ScrollView>
</LinearLayout>
