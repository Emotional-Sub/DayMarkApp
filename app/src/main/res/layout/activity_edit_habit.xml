<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/pageTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="新增打卡事件"
            android:textColor="@color/ink"
            android:textSize="26sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/titleEdit"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_input"
            android:hint="事件标题"
            android:paddingHorizontal="14dp"
            android:singleLine="true"
            android:textColor="@color/ink"
            android:textColorHint="@color/muted" />

        <EditText
            android:id="@+id/contentEdit"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:gravity="top"
            android:hint="事件内容 / 目标说明"
            android:inputType="textMultiLine"
            android:padding="14dp"
            android:textColor="@color/ink"
            android:textColorHint="@color/muted" />

        <EditText
            android:id="@+id/timeEdit"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="点击选择时间，例如 07:30"
            android:paddingHorizontal="14dp"
            android:singleLine="true"
            android:textColor="@color/ink"
            android:textColorHint="@color/muted" />

        <Spinner
            android:id="@+id/categorySpinner"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="打卡频率"
            android:textColor="@color/muted"
            android:textSize="13sp" />

        <Spinner
            android:id="@+id/frequencySpinner"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="10dp" />

        <!-- Shown only for "每周指定星期" (FREQ_WEEKLY_DAYS). -->
        <LinearLayout
            android:id="@+id/weekdayRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <ToggleButton
                android:id="@+id/dayMon"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:textColor="@color/ink"
                android:textOff="一"
                android:textOn="一"
                android:textSize="13sp" />

            <ToggleButton
                android:id="@+id/dayTue"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:textColor="@color/ink"
                android:textOff="二"
                android:textOn="二"
                android:textSize="13sp" />

            <ToggleButton
                android:id="@+id/dayWed"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:textColor="@color/ink"
                android:textOff="三"
                android:textOn="三"
                android:textSize="13sp" />

            <ToggleButton
                android:id="@+id/dayThu"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:textColor="@color/ink"
                android:textOff="四"
                android:textOn="四"
                android:textSize="13sp" />

            <ToggleButton
                android:id="@+id/dayFri"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:textColor="@color/ink"
                android:textOff="五"
                android:textOn="五"
                android:textSize="13sp" />

            <ToggleButton
                android:id="@+id/daySat"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:textColor="@color/ink"
                android:textOff="六"
                android:textOn="六"
                android:textSize="13sp" />

            <ToggleButton
                android:id="@+id/daySun"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:textColor="@color/ink"
                android:textOff="日"
                android:textOn="日"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Shown only for "每周N次" (FREQ_WEEKLY_COUNT). -->
        <EditText
            android:id="@+id/frequencyCountEdit"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="每周打卡次数，例如 3"
            android:inputType="number"
            android:paddingHorizontal="14dp"
            android:singleLine="true"
            android:textColor="@color/ink"
            android:textColorHint="@color/muted"
            android:visibility="gone" />

        <EditText
            android:id="@+id/targetDaysEdit"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="目标坚持天数，可不填，例如 21"
            android:inputType="number"
            android:paddingHorizontal="14dp"
            android:singleLine="true"
            android:textColor="@color/ink"
            android:textColorHint="@color/muted" />

        <EditText
            android:id="@+id/reminderEdit"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="点击选择提醒时间，可不填（长按清除）"
            android:paddingHorizontal="14dp"
            android:singleLine="true"
            android:textColor="@color/ink"
            android:textColorHint="@color/muted" />

        <ImageView
            android:id="@+id/previewImage"
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_photo"
            android:contentDescription="图片预览"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/cameraButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_outline"
                android:text="拍照"
                android:textColor="@color/brand_green"
                android:textSize="15sp" />

            <Button
                android:id="@+id/galleryButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_outline"
                android:text="相册选择"
                android:textColor="@color/brand_green"
                android:textSize="15sp" />
        </LinearLayout>

        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_primary"
            android:text="保存事件"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/cancelButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_outline"
            android:text="取消"
            android:textColor="@color/brand_green"
            android:textSize="15sp" />
    </LinearLayout>
</ScrollView>
