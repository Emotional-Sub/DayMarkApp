<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="个人主页"
            android:textColor="@color/ink"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Account + overview card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/profileNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/ink"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profileAccountText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/muted"
                android:textSize="13sp" />

            <Button
                android:id="@+id/editProfileButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_outline"
                android:minHeight="0dp"
                android:paddingLeft="16dp"
                android:paddingTop="8dp"
                android:paddingRight="16dp"
                android:paddingBottom="8dp"
                android:text="编辑账号"
                android:textColor="@color/brand_green"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/profileOverviewText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/ink"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Yearly heatmap card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="打卡热力图"
                android:textColor="@color/ink"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.example.daymark.HeatmapView
                android:id="@+id/heatmapView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"
                android:text="少          多"
                android:textColor="@color/muted"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Category stats card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="分类统计"
                android:textColor="@color/ink"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/categoryStatsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/ink"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Achievements card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="个人勋章"
                android:textColor="@color/ink"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/achievementContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- Account settings -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="账号设置"
            android:textColor="@color/muted"
            android:textSize="13sp" />

        <Button
            android:id="@+id/changePasswordButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_button_outline"
            android:text="修改密码"
            android:textColor="@color/brand_green"
            android:textSize="15sp" />

        <Button
            android:id="@+id/deleteAccountButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_outline"
            android:text="删除账号"
            android:textColor="@color/brand_coral"
            android:textSize="15sp" />

        <Button
            android:id="@+id/backButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_button_outline"
            android:text="返回"
            android:textColor="@color/brand_green"
            android:textSize="15sp" />
    </LinearLayout>
</ScrollView>
